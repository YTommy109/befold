--swiftversion 6.0
--indent 4
--self remove
--stripunusedargs closure-only
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--exclude .build,befold/Resources
# プロジェクト規約（coding_rule.md）が @Suite と Sendable の明示を要求するため、
# それらを冗長として除去するルールは無効化する
--disable redundantSwiftTestingSuite,redundantSendable
